---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 Hi, I'm Jared Bronen</h1>
			<p>
				I am a Brooklyn-based writer, filmmaker, and comedian. Since 2019, I've been a writer for the Upright Citizens Brigade (UCB) NY’s Maude Night, where I currently write and act for the team <strong>Ponyboy</strong>.
			</p>
			<p>
				My background includes writing for CollegeHumor and performing as "Mike Fink" in the <em>Jake & Amir</em> web series.
			</p>

			<h2>Projects</h2>
			
			<h3>Films & Shorts</h3>
			<ul>
				<li>
					<strong>The Debut</strong>: A short film about a comedy character debut. Finalist at Just for Laughs Montreal (2025).
				</li>
				<li>
					<strong>Pick a Random Number</strong>: A DocuFiction/Comedy exploring randomness in computing. Awarded Best Film (Hidden Gems) at Tootsie’s Video Vault (2024) and Best Dramatic Short at Raw Science Film Festival (2023).
				</li>
			</ul>

			<h3>Live Shows</h3>
			<ul>
				<li>
					<strong>The Trash King</strong>: A monthly tournament of bits at UCB NYC. Featured in the New York Comedy Festival, <em>Jezebel</em>, and <em>Time Out NY</em>.
				</li>
			</ul>

			<h3>Scripts & Sketches</h3>
			<ul>
				<li><strong>Shrek’s in the City</strong>: A parody pilot.</li>
				<li><strong>The Content Moderator</strong>: A horror/sci-fi feature screenplay.</li>
				<li><strong>Notable Sketches</strong>: <em>Foodtown</em>, <em>Paint and Pinot</em>, and <em>I Am the Most New York</em>.</li>
			</ul>

			<p>
				Feel free to reach out at <a href="mailto:jbronen@gmail.com">jbronen@gmail.com</a> or find me on Instagram <a href="https://instagram.com/jbronen">@jbronen</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
